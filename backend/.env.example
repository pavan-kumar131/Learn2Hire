# Copy this file to .env in this same folder (backend/.env), fill in values, then restart the API. Never commit .env.
# If teammates get HTTP 503 on "Send code" at signup, they are missing this file or SMTP_* variables.

MONGODB_URI=mongodb://192.168.3.165:27017/learn2hire
# Required in production (≥32 random characters). In development you may use a shorter secret and see a warning.
JWT_SECRET=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY5YTZiNGI3NTdjN2MyMTdhMGI2MzAzOCIsImlhdCI6MTc3MjUzNDE5NiwiZXhwIjoxNzczMTM4OTk2fQ.JMaoL6Pk1jtsCReXeRNDLDpE1W2P-1cCKZRF2yvMhvA
PORT=5000

# Comma-separated browser origins allowed to call this API with credentials (e.g. https://app.example.com).
# In development you may omit this (any origin is allowed). In production, CORS_ORIGIN is required or the server will exit.
CORS_ORIGIN=https://learn2hire.patels.club

# Behind a reverse proxy (nginx, etc.) set to 1 or true so rate limits use the client IP from X-Forwarded-For.
# TRUST_PROXY=1

# Optional rate limits (defaults are safe for small/medium traffic).
# RATE_LIMIT_API_PER_MINUTE=500
# RATE_LIMIT_AUTH_PER_15MIN=100

# Used in OTP / password-reset emails (links back to the app). This repo's Vite dev server defaults to port 3000.
FRONTEND_URL=https://learn2hire.patels.club

# --- Email (signup OTP + forgot-password OTP use the same SMTP) ---
# Option A: custom host (Gmail, Outlook, etc.)
#SMTP_HOST=smtp.gmail.com
#SMTP_PORT=587
# true for port 465 (SSL); false for 587 (STARTTLS)
#SMTP_SECURE=false
#SMTP_USER=your-address@gmail.com
# Gmail: use a 16-character App Password, not your normal password (spaces are stripped automatically).
#SMTP_PASS=

# Option B: nodemailer well-known service instead of host (set SMTP_SERVICE and still set SMTP_USER / SMTP_PASS)
# SMTP_SERVICE=Gmail

# Optional From header (defaults to SMTP_FROM_NAME + SMTP_USER)
# SMTP_FROM=your-address@gmail.com
# SMTP_FROM_NAME=Learn2Hire

# Local dev only: return OTP in API JSON when SMTP is not set or for debugging. Never true in production.
#OTP_ECHO_TO_CLIENT=false
